# ══════════════════════════════════════════════════════════
# BrothaBot v5.0 — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.
# ══════════════════════════════════════════════════════════

# ── Required ───────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Solana / Helius ────────────────────────────────────────
# Get a free key at https://helius.dev
HELIUS_API_KEY=your_helius_api_key_here

# ── Bot Owner ──────────────────────────────────────────────
# Your Telegram user ID (find it via @userinfobot)
OWNER_ID=your_telegram_user_id_here

# ── BROTHA Token ───────────────────────────────────────────
# Set after token launch on pump.fun
BROTHA_MINT=BROTHA_MINT_ADDRESS_HERE
BROTHA_DEX=https://dexscreener.com/solana/BROTHA_MINT_ADDRESS_HERE
BROTHA_PUMP=https://pump.fun/BROTHA_MINT_ADDRESS_HERE

# ── Gift Cards (Optional) ──────────────────────────────────
# Apply at https://www.bitrefill.com/integrate/
BITREFILL_API_KEY=

# ── x402 Payments (Optional) ──────────────────────────────
# Enable micropayment protocol support
X402_ENABLED=0
X402_FACILITATOR=https://x402.org/facilitator

# ── Local AI (Optional) ────────────────────────────────────
# Requires Ollama running locally: https://ollama.com
OLLAMA_URL=http://localhost:11434

# ── Misc ───────────────────────────────────────────────────
# Set to 1 on servers with <2GB RAM
LOW_RAM=0

# Database path (default: current directory)
DB_PATH=brothabot.db

# Unlock all features for all users (dev/demo mode)
FREE_MODE=0
